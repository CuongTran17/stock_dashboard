{
  "name": "vn-stock-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "dev:python": "uvicorn stock_api_server:app --host 0.0.0.0 --port 8000 --reload",
    "start:python": "uvicorn stock_api_server:app --host 0.0.0.0 --port 8000",
    "dev:python:venv": ".\\.venv\\Scripts\\python.exe -m uvicorn stock_api_server:app --host 127.0.0.1 --port 8000 --reload",
    "start:python:venv": ".\\.venv\\Scripts\\python.exe -m uvicorn stock_api_server:app --host 127.0.0.1 --port 8000",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0"
  }
}
