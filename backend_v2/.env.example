# ======= MYSQL DATABASE CONFIGURATION =======
MYSQL_URL=mysql+mysqlconnector://root:YOUR_PASSWORD@localhost/vnstock_data

# ======= JWT SECURITY =======
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRE_HOURS=24

# ======= VNSTOCK VIP CONFIGURATION ========
VNSTOCK_API_KEY=your_dnse_api_key_here

# ======= SEPAY PAYMENT CONFIGURATION ========
SEPAY_ENV=sandbox
SEPAY_MERCHANT_ID=SP-LIVE-XXXXXXXX
SEPAY_SECRET_KEY=spsk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEPAY_BANK_NAME=MB
SEPAY_BANK_ACCOUNT=
SEPAY_ACCOUNT_NAME=

# ======= URL CONFIGURATION =======
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://localhost:8000
FRONTEND_CALLBACK_URL=http://localhost:5174

# ======= NGROK (local dev only) =======
IPN_PORT=3001
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DEV_DOMAIN=your-subdomain.ngrok-free.dev
IPN_URL=https://your-subdomain.ngrok-free.dev/api/payment/sepay/webhook
SEPAY_IPN_URL=https://your-subdomain.ngrok-free.dev/api/payment/sepay/webhook

# ======= REDIS (optional — in-memory fallback if not set) =======
REDIS_URL=redis://localhost:6379/0

# ======= MOCK INTRADAY STREAMER (Phase 4.2) =======
# Bật để sinh tick giả lập trong giờ giao dịch (khi vnstock bị disable).
# Tắt trong production khi đã có nguồn dữ liệu thực.
ENABLE_MOCK_INTRADAY=false
MOCK_TICK_INTERVAL_SECONDS=5

# ======= KAGGLE TRADING-R1 AI =======
KAGGLE_API_URL=https://your-kaggle-ngrok.ngrok-free.dev
