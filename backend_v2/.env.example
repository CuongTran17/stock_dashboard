# ======= MYSQL DATABASE CONFIGURATION =======
MYSQL_URL=mysql+mysqlconnector://root:YOUR_PASSWORD@localhost/vnstock_data
MYSQL_ASYNC_URL=mysql+aiomysql://root:YOUR_PASSWORD@localhost/vnstock_data
DB_MIGRATIONS_ENABLED=true
# Keep true for local/dev upgrades from older auto-DDL schemas. Set false in production after migrations are established.
DB_LEGACY_AUTO_DDL=true

# ======= JWT SECURITY =======
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRE_HOURS=24

# ======= VNSTOCK VIP CONFIGURATION ========
VNSTOCK_API_KEY=your_dnse_api_key_here
VNAI_API_KEY=
VNSTOCK_QUOTE_SOURCE=vci
VNSTOCK_COMPANY_SOURCE=vci
VNSTOCK_MIN_REQUEST_INTERVAL_SECONDS=1.05
VNSTOCK_MAX_REQUESTS_PER_MINUTE=55
VNSTOCK_FETCH_RETRY_ATTEMPTS=3
VNSTOCK_INTRADAY_PAGE_SIZE=50
VNSTOCK_MAX_TICKS_PER_SYMBOL=1200
VNSTOCK_HISTORY_LOOKBACK_DAYS=365
VNSTOCK_OUT_OF_SESSION_POLL_SECONDS=60
VNSTOCK_INTRADAY_CONCURRENCY=4
VNSTOCK_HISTORY_PRELOAD_CONCURRENCY=1
VNSTOCK_HISTORY_PRELOAD_SYMBOL_LIMIT=5
VNSTOCK_INTRADAY_STALE_SECONDS=20
VNSTOCK_INTRADAY_REFRESH_TIMEOUT_SECONDS=4.0
VNSTOCK_TECHNICAL_CACHE_TTL_SECONDS=900
VNSTOCK_NEWS_CACHE_TTL_SECONDS=300
VNSTOCK_EVENTS_CACHE_TTL_SECONDS=900
VNSTOCK_OVERVIEW_CACHE_TTL_SECONDS=21600
VNSTOCK_FINANCIAL_CACHE_TTL_SECONDS=21600
VNSTOCK_NEWS_PER_SYMBOL=20
VNSTOCK_EVENTS_PER_SYMBOL=12
VNSTOCK_FINANCIAL_MAX_ROWS=120
VNSTOCK_MARKET_INDEX_CACHE_TTL_SECONDS=180
VNSTOCK_MARKET_INDEX_LOOKBACK_DAYS=540

# ======= SEPAY PAYMENT CONFIGURATION ========
SEPAY_ENV=sandbox
SEPAY_MERCHANT_ID=SP-LIVE-XXXXXXXX
SEPAY_SECRET_KEY=spsk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEPAY_BANK_NAME=MB
SEPAY_BANK_ACCOUNT=
SEPAY_ACCOUNT_NAME=

# ======= URL CONFIGURATION =======
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://localhost:8000
FRONTEND_CALLBACK_URL=http://localhost:5174

# ======= NGROK (local dev only) =======
IPN_PORT=3001
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DEV_DOMAIN=your-subdomain.ngrok-free.dev
IPN_URL=https://your-subdomain.ngrok-free.dev/api/payment/sepay/webhook
SEPAY_IPN_URL=https://your-subdomain.ngrok-free.dev/api/payment/sepay/webhook

# ======= REDIS (optional — in-memory fallback if not set) =======
REDIS_URL=redis://localhost:6379/0

# ======= ETL RUNTIME =======
ETL_SYMBOLS=FPT,VCB,VIC
ETL_LOOKBACK_DAYS=365
ETL_TICK_SOURCE=lake
ETL_RUN_MODE=incremental
ETL_INCREMENTAL_OVERLAP_DAYS=7
ETL_CACHE_WARMUP_SCOPE=etl
VN30_EOD_JOB_ENABLED=false
VNSTOCK_PRELOAD_REFERENCE_CACHE=true
VNSTOCK_PRELOAD_FORCE_REFRESH=false
VNSTOCK_PRELOAD_SYMBOL_LIMIT=5

# ======= MOCK INTRADAY STREAMER (Phase 4.2) =======
# Bật để sinh tick giả lập trong giờ giao dịch (khi vnstock bị disable).
# Tắt trong production khi đã có nguồn dữ liệu thực.
ENABLE_MOCK_INTRADAY=false
MOCK_TICK_INTERVAL_SECONDS=5

# ======= KAGGLE TRADING-R1 AI =======
KAGGLE_API_URL=https://your-kaggle-ngrok.ngrok-free.dev
